---
import '../styles/global.css'
import { SITE } from '../lib/config'

interface Props {
  title?: string
  description?: string
}

const { title = `${SITE.name} — ${SITE.tagline}`, description = `Portfolio demo — a fictional craft brewery site built by Upstate Web Co.` } = Astro.props
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="noindex, nofollow" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://images.unsplash.com/photo-1519741497674-611481863552?w=1200<meta property="og:description" content={description} />q=80" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://images.unsplash.com" />
</head>
<body class="bg-dark text-cream antialiased">
  <!-- Nav -->
  <nav class="fixed top-0 w-full z-50 bg-dark/95 backdrop-blur-sm border-b border-warm-gray/20">
    <div class="mx-auto max-w-6xl flex items-center justify-between px-6 py-4">
      <a href="/" class="text-xl font-bold text-amber">{SITE.name}</a>
      <div class="hidden md:flex items-center gap-6 text-sm">
        <a href="#taplist" class="text-warm-light/70 hover:text-amber transition-colors">On Tap</a>
        <a href="#events" class="text-warm-light/70 hover:text-amber transition-colors">Events</a>
        <a href="#private-events" class="text-warm-light/70 hover:text-amber transition-colors">Private Events</a>
        <a href="#visit" class="text-warm-light/70 hover:text-amber transition-colors">Visit</a>
        <a href="#contact" class="rounded-lg bg-amber px-4 py-2 font-medium text-dark hover:bg-amber-light transition-colors">Book the Taproom</a>
      </div>
      <!-- Mobile menu button -->
      <button id="mobile-menu-btn" class="md:hidden text-amber p-2" aria-label="Open menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu overlay -->
  <div id="mobile-menu" class="fixed inset-0 z-[60] bg-dark/95 backdrop-blur-sm hidden flex-col items-center justify-center gap-6 text-lg">
    <button id="mobile-menu-close" class="absolute top-6 right-6 text-amber p-2" aria-label="Close menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
    <a href="#taplist" class="text-warm-light/70 hover:text-amber transition-colors">On Tap</a>
    <a href="#events" class="text-warm-light/70 hover:text-amber transition-colors">Events</a>
    <a href="#private-events" class="text-warm-light/70 hover:text-amber transition-colors">Private Events</a>
    <a href="#visit" class="text-warm-light/70 hover:text-amber transition-colors">Visit</a>
    <a href="#contact" class="rounded-lg bg-amber px-5 py-3 font-medium text-dark hover:bg-amber-light transition-colors">Book the Taproom</a>
  </div>

  <main class="pt-16">
    <slot />
  </main>

  <!-- Demo Disclaimer -->
  <div class="bg-yellow-50 border-y border-yellow-200 py-3 px-6 text-center">
    <p class="text-xs text-yellow-800">
      <strong>Portfolio Demo</strong> — This is a fictional business created by <a href="https://upstate-web.com" class="underline hover:text-yellow-900">Upstate Web Co</a>. All names, addresses, and details are entirely fictional. Not a real brewery.
    </p>
  </div>

  <!-- Footer -->
  <footer class="border-t border-warm-gray/20 bg-dark-lighter">
    <div class="mx-auto max-w-6xl px-6 py-10">
      <div class="grid md:grid-cols-3 gap-8">
        <div>
          <p class="text-lg font-bold text-amber">{SITE.name}</p>
          <p class="text-sm text-warm-gray mt-2">{SITE.tagline}</p>
        </div>
        <div class="text-sm text-warm-gray">
          <p class="font-medium text-warm-light mb-2">Hours</p>
          <p>Tue–Wed: 4pm–10pm</p>
          <p>Thu: 4pm–11pm</p>
          <p>Fri: 2pm–12am</p>
          <p>Sat: 12pm–12am</p>
          <p>Sun: 12pm–8pm</p>
          <p>Mon: Closed</p>
        </div>
        <div class="text-sm text-warm-gray">
          <p class="font-medium text-warm-light mb-2">Contact</p>
          <p>{SITE.address}</p>
          <p class="mt-1">{SITE.phone}</p>
          <p><a href={`mailto:${SITE.email}`} class="hover:text-amber">{SITE.email}</a></p>
        </div>
      </div>
      <div class="mt-8 pt-6 border-t border-warm-gray/20 text-center text-xs text-warm-gray">
        &copy; {new Date().getFullYear()} {SITE.name}. All rights reserved.
        <span class="mx-2">|</span>
        <span>Built by <a href="https://upstate-web.com" class="text-amber hover:underline">Upstate Web Co</a></span>
      </div>
    </div>
  </footer>

  <!-- Inline AI: contextual search bar on homepage, not a floating bubble -->

  <script>
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const close = document.getElementById('mobile-menu-close');
    btn?.addEventListener('click', () => menu?.classList.replace('hidden', 'flex'));
    close?.addEventListener('click', () => menu?.classList.replace('flex', 'hidden'));
    menu?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => menu?.classList.replace('flex', 'hidden')));
  </script>
</body>
</html>
