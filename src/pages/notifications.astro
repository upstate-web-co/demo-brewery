---
/**
 * Notification mockup — "phone reveal" for the Brewery ad.
 * Script: Group of friends booking trivia night while brewery owner is somewhere else.
 * Tagline: UWC: they'll find you.
 */
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Notifications — Copper Rail Brewing Co</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            amber: '#D97706',
            dark: '#1A1410',
          }
        }
      }
    }
  </script>
</head>
<body class="bg-dark min-h-screen text-white">
  <!-- Status Bar Mockup -->
  <div class="flex items-center justify-between px-6 py-2 text-xs text-white/60">
    <span>7:30 PM</span>
    <div class="flex items-center gap-1"><span>5G</span><span>📶</span><span>🔋 71%</span></div>
  </div>

  <!-- App Header -->
  <div class="px-6 pt-4 pb-6">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm text-white/50">Good evening</p>
        <h1 class="text-2xl font-bold">Copper Rail Brewing Co</h1>
      </div>
      <div class="relative">
        <div class="w-10 h-10 rounded-full bg-amber/20 flex items-center justify-center text-lg">🍺</div>
        <div class="absolute -top-1 -right-1 w-5 h-5 rounded-full bg-red-500 flex items-center justify-center text-[10px] font-bold">8</div>
      </div>
    </div>
  </div>

  <!-- Summary Cards -->
  <div class="px-6 grid grid-cols-3 gap-3 mb-6">
    <div class="bg-white/5 border border-white/10 rounded-xl p-3 text-center">
      <p class="text-2xl font-bold text-amber">2</p>
      <p class="text-[10px] text-white/50 mt-1">Reservations</p>
    </div>
    <div class="bg-white/5 border border-white/10 rounded-xl p-3 text-center">
      <p class="text-2xl font-bold text-green-400">$340</p>
      <p class="text-[10px] text-white/50 mt-1">Merch + Deposits</p>
    </div>
    <div class="bg-white/5 border border-white/10 rounded-xl p-3 text-center">
      <p class="text-2xl font-bold text-blue-400">4</p>
      <p class="text-[10px] text-white/50 mt-1">AI Chats</p>
    </div>
  </div>

  <!-- Timeline -->
  <div class="px-6">
    <h2 class="text-sm font-semibold text-white/40 uppercase tracking-wider mb-4">While you were away</h2>
    <div class="space-y-3">
      <div class="bg-white/5 border border-white/10 rounded-xl p-4">
        <div class="flex items-start justify-between">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-amber/20 flex items-center justify-center text-sm">📅</div>
            <div>
              <p class="text-sm font-medium">Trivia Night reservation: 8 people, Friday 7pm</p>
              <p class="text-xs text-white/40">Table reserved · deposit confirmed</p>
            </div>
          </div>
          <span class="text-[10px] text-white/30">5m ago</span>
        </div>
      </div>

      <div class="bg-white/5 border border-white/10 rounded-xl p-4">
        <div class="flex items-start justify-between">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-blue-500/20 flex items-center justify-center text-sm">💬</div>
            <div>
              <p class="text-sm font-medium">AI recommended the Copper Horse IPA</p>
              <p class="text-xs text-white/40">They ordered a flight · 4 pours</p>
            </div>
          </div>
          <span class="text-[10px] text-white/30">12m ago</span>
        </div>
      </div>

      <div class="bg-white/5 border border-white/10 rounded-xl p-4">
        <div class="flex items-start justify-between">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-green-500/20 flex items-center justify-center text-sm">💳</div>
            <div>
              <p class="text-sm font-medium">Merch order: 2 Logo Tees + 4 Pint Glasses — $104</p>
              <p class="text-xs text-white/40">via Stripe · shipping to Greenville</p>
            </div>
          </div>
          <span class="text-[10px] text-white/30">20m ago</span>
        </div>
      </div>

      <div class="bg-white/5 border border-white/10 rounded-xl p-4">
        <div class="flex items-start justify-between">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-amber/20 flex items-center justify-center text-sm">🎉</div>
            <div>
              <p class="text-sm font-medium">Private event inquiry: birthday, 30 guests</p>
              <p class="text-xs text-white/40">Next month · AI gathered all details</p>
            </div>
          </div>
          <span class="text-[10px] text-white/30">35m ago</span>
        </div>
      </div>

      <div class="bg-white/5 border border-white/10 rounded-xl p-4">
        <div class="flex items-start justify-between">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-blue-500/20 flex items-center justify-center text-sm">💬</div>
            <div>
              <p class="text-sm font-medium">AI answered "Do you have gluten-free options?"</p>
              <p class="text-xs text-white/40">Recommended the Copper Light Lager · they added to cart</p>
            </div>
          </div>
          <span class="text-[10px] text-white/30">50m ago</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Summary -->
  <div class="px-6 py-8 mt-4">
    <div class="bg-amber/10 border border-amber/20 rounded-xl p-5 text-center">
      <p class="text-amber text-sm font-medium">Your taproom is filling up. You don't need to be there yet.</p>
      <p class="text-white/50 text-xs mt-1">2 reservations · 4 AI conversations · $340 confirmed</p>
    </div>
  </div>

  <!-- UWC Branding -->
  <div class="fixed bottom-0 left-0 right-0 bg-gradient-to-t from-dark via-dark/80 to-transparent py-6 px-6">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-white text-lg font-bold">UWC</p>
        <p class="text-amber text-sm">They'll find you.</p>
      </div>
      <p class="text-white/30 text-xs">upstate-web.com</p>
    </div>
  </div>
</body>
</html>
