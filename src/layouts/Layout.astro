---
import '../styles/global.css'
import { SITE } from '../lib/config'

interface Props {
  title?: string
  description?: string
}

const { title = `${SITE.name} — ${SITE.tagline}`, description = `${SITE.tagline} Craft brewery and taproom in Greenville, SC.` } = Astro.props
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://images.unsplash.com" />
</head>
<body class="bg-dark text-cream antialiased">
  <!-- Nav -->
  <nav class="fixed top-0 w-full z-50 bg-dark/95 backdrop-blur-sm border-b border-warm-gray/20">
    <div class="mx-auto max-w-6xl flex items-center justify-between px-6 py-4">
      <a href="/" class="text-xl font-bold text-amber">{SITE.name}</a>
      <div class="hidden md:flex items-center gap-6 text-sm">
        <a href="#taplist" class="text-warm-light/70 hover:text-amber transition-colors">On Tap</a>
        <a href="#events" class="text-warm-light/70 hover:text-amber transition-colors">Events</a>
        <a href="#private-events" class="text-warm-light/70 hover:text-amber transition-colors">Private Events</a>
        <a href="#visit" class="text-warm-light/70 hover:text-amber transition-colors">Visit</a>
        <a href="#contact" class="rounded-lg bg-amber px-4 py-2 font-medium text-dark hover:bg-amber-light transition-colors">Book the Taproom</a>
        <button id="cart-toggle" class="relative text-warm-light/70 hover:text-amber transition-colors" aria-label="Open cart">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007ZM8.625 10.5a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm7.5 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"/></svg>
          <span id="cart-count" class="hidden absolute -top-2 -right-2 bg-amber text-dark text-xs font-bold rounded-full w-5 h-5 flex items-center justify-center">0</span>
        </button>
      </div>
    </div>
  </nav>

  <main class="pt-16">
    <slot />
  </main>

  <!-- Demo Disclaimer -->
  <div class="bg-yellow-50 border-y border-yellow-200 py-3 px-6 text-center">
    <p class="text-xs text-yellow-800">
      <strong>Portfolio Demo</strong> — This is a sample site built by <a href="https://upstate-web.com" class="underline hover:text-yellow-900">Upstate Web Co</a> to showcase what we build for this industry. This is not a real business.
    </p>
  </div>

  <!-- Footer -->
  <footer class="border-t border-warm-gray/20 bg-dark-lighter">
    <div class="mx-auto max-w-6xl px-6 py-10">
      <div class="grid md:grid-cols-3 gap-8">
        <div>
          <p class="text-lg font-bold text-amber">{SITE.name}</p>
          <p class="text-sm text-warm-gray mt-2">{SITE.tagline}</p>
        </div>
        <div class="text-sm text-warm-gray">
          <p class="font-medium text-warm-light mb-2">Hours</p>
          <p>Tue–Wed: 4pm–10pm</p>
          <p>Thu: 4pm–11pm</p>
          <p>Fri: 2pm–12am</p>
          <p>Sat: 12pm–12am</p>
          <p>Sun: 12pm–8pm</p>
          <p>Mon: Closed</p>
        </div>
        <div class="text-sm text-warm-gray">
          <p class="font-medium text-warm-light mb-2">Contact</p>
          <p>{SITE.address}</p>
          <p class="mt-1">{SITE.phone}</p>
          <p><a href={`mailto:${SITE.email}`} class="hover:text-amber">{SITE.email}</a></p>
        </div>
      </div>
      <div class="mt-8 pt-6 border-t border-warm-gray/20 text-center text-xs text-warm-gray">
        &copy; {new Date().getFullYear()} {SITE.name}. All rights reserved.
        <span class="mx-2">|</span>
        <span>Built by <a href="https://upstate-web.com" class="text-amber hover:underline">Upstate Web Co</a></span>
      </div>
    </div>
  </footer>

  <!-- Cart Drawer -->
  <div id="cart-backdrop" class="fixed inset-0 z-[70] bg-dark/60 backdrop-blur-sm hidden"></div>
  <div id="cart-drawer" class="fixed top-0 right-0 z-[80] h-full w-full max-w-sm bg-dark-lighter border-l border-warm-gray/20 shadow-xl translate-x-full transition-transform duration-300 flex flex-col">
    <div class="flex items-center justify-between px-6 py-4 border-b border-warm-gray/20">
      <h2 class="text-lg font-bold text-warm-light">Your Cart</h2>
      <button id="cart-close" class="text-warm-gray hover:text-warm-light p-1" aria-label="Close cart">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <div id="cart-items" class="flex-1 overflow-y-auto px-6 py-4"></div>
    <div id="cart-footer" class="hidden border-t border-warm-gray/20 px-6 py-4">
      <div class="flex justify-between text-sm font-medium text-warm-light mb-4">
        <span>Total</span><span id="cart-subtotal">$0</span>
      </div>
      <button id="cart-checkout" class="w-full rounded-lg bg-amber px-6 py-3 font-bold text-dark hover:bg-amber-light transition-colors text-sm">Checkout</button>
      <div id="cart-demo-msg" class="hidden mt-3 rounded-lg bg-amber/10 border border-amber/20 p-3 text-xs text-amber text-center leading-relaxed">
        This is a portfolio demo by <a href="https://upstate-web.com" class="underline">Upstate Web Co</a>. In production, this connects to Stripe for secure checkout.
      </div>
    </div>
    <div id="cart-empty" class="flex-1 flex items-center justify-center text-sm text-warm-gray px-6 text-center">Your cart is empty. Browse our merch!</div>
  </div>

  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => { if (entry.isIntersecting) entry.target.classList.add('visible') })
    }, { threshold: 0.08, rootMargin: '-20px' })
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el))

    // Cart
    const cart: { name: string; price: number; quantity: number }[] = []
    function parsePrice(p: string): number { return parseFloat(p.replace(/[^0-9.]/g, '')) || 0 }
    function updateCartUI() {
      const count = cart.reduce((s, i) => s + i.quantity, 0)
      const subtotal = cart.reduce((s, i) => s + i.price * i.quantity, 0)
      const c = document.getElementById('cart-count')!; c.textContent = String(count); c.classList.toggle('hidden', count === 0)
      const items = document.getElementById('cart-items')!, footer = document.getElementById('cart-footer')!, empty = document.getElementById('cart-empty')!
      if (cart.length === 0) { items.innerHTML = ''; footer.classList.add('hidden'); empty.classList.remove('hidden') }
      else {
        empty.classList.add('hidden'); footer.classList.remove('hidden')
        document.getElementById('cart-subtotal')!.textContent = `$${subtotal.toFixed(2)}`
        items.innerHTML = cart.map((it, i) => `<div class="flex items-start justify-between py-3 ${i > 0 ? 'border-t border-warm-gray/15' : ''}"><div class="flex-1 min-w-0"><p class="text-sm font-medium text-warm-light">${it.name}</p><p class="text-xs text-warm-gray mt-0.5">$${it.price.toFixed(2)}</p></div><div class="text-right ml-3"><p class="text-sm font-medium text-amber">$${(it.price * it.quantity).toFixed(2)}</p><button data-r="${i}" class="text-xs text-warm-gray hover:text-red-400 mt-1">Remove</button></div></div>`).join('')
        items.querySelectorAll('[data-r]').forEach(b => b.addEventListener('click', () => { cart.splice(Number((b as HTMLElement).dataset.r), 1); updateCartUI() }))
      }
    }
    function openCart() { document.getElementById('cart-backdrop')!.classList.remove('hidden'); document.getElementById('cart-drawer')!.classList.remove('translate-x-full') }
    function closeCart() { document.getElementById('cart-drawer')!.classList.add('translate-x-full'); document.getElementById('cart-backdrop')!.classList.add('hidden') }
    document.getElementById('cart-toggle')?.addEventListener('click', openCart)
    document.getElementById('cart-close')?.addEventListener('click', closeCart)
    document.getElementById('cart-backdrop')?.addEventListener('click', closeCart)
    document.getElementById('cart-checkout')?.addEventListener('click', () => { document.getElementById('cart-demo-msg')!.classList.remove('hidden') })
    ;(window as any).__addToCart = function(name: string, priceStr: string) {
      const price = parsePrice(priceStr)
      const existing = cart.find(i => i.name === name)
      if (existing) { existing.quantity++ } else { cart.push({ name, price, quantity: 1 }) }
      updateCartUI(); openCart()
    }
  </script>
</body>
</html>
